RSS_SERVICE_ENV=production
RSS_SERVICE_HOST=0.0.0.0
RSS_SERVICE_PORT=8787
RSS_SERVICE_API_TOKEN=change-me

RSS_DB_PATH=/var/lib/rss-service/rss.sqlite3
RSS_REPORTS_DIR=/reports
RSS_CONFIG_DIR=/app/config
RSS_TIMEZONE=Asia/Singapore

RSS_USER_AGENT=rss-service/1.0 (+local-hermes)
RSS_FETCH_CONCURRENCY=8
RSS_FETCH_TIMEOUT_SECONDS=20
RSS_FETCH_RETRY_TIMES=2
RSS_PER_DOMAIN_CONCURRENCY=2
RSS_SUMMARY_MAX_LENGTH=240

RSS_ENABLE_INTERNAL_SCHEDULER=false

RSS_LOG_LEVEL=INFO
